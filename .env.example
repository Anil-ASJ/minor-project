# Copy this file to .env and fill in your API key(s)
# Example:
# GOOGLE_API_KEY=your_google_api_key_here
# or
# GEMINI_API_KEY=your_google_api_key_here

# Optional: specify backend port
# PORT=5000

# Notes:
# - Do NOT commit your real API key to source control.
# - The server will exit if no API key is provided in environment.
